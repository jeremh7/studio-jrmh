APP_ENV=dev
APP_SECRET=CHANGE_ME_32_CHARS_MINIMUM

DATABASE_URL="postgresql://app:CHANGE_ME@127.0.0.1:5432/studio_jrmh?serverVersion=16&charset=utf8"

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_IN_PRODUCTION
###< lexik/jwt-authentication-bundle ###
JWT_TTL=3600

# Mailer — Brevo (clé API dans .env.local)
MAILER_DSN=brevo+api://YOUR_BREVO_API_KEY@default
MAILER_FROM=studio.jrmh@gmail.com
MAILER_FROM_NAME="Studiø JRMH"
# En dev : redirige tous les emails vers cette adresse (laisser vide en prod)
MAILER_REDIRECT_TO=

# Admin
ADMIN_EMAIL=studio.jrmh@gmail.com
ADMIN_PASSWORD=CHANGE_ME

# Upload & Frontend
UPLOAD_DIR=%kernel.project_dir%/var/uploads
PRIVATE_DIR=%kernel.project_dir%/var/private
UPLOAD_MAX_SIZE=20971520
FRONTEND_URL=http://localhost:3000
DEFAULT_URI=http://localhost

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
