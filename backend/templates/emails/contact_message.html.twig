{% extends 'emails/base.html.twig' %}

{% block subject %}[Contact] {{ subject ?: 'Nouveau message' }} — {{ senderName }}{% endblock %}
{% block header_title %}Nouveau message{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:20px;font-weight:300;color:#0a0a0a;">
        Vous avez reçu un message via le formulaire de contact.
    </h2>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:0 0 24px;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Nom :</strong> {{ senderName }}
                </p>
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Email :</strong>
                    <a href="mailto:{{ senderEmail }}" style="color:#0a0a0a;">{{ senderEmail }}</a>
                </p>
                {% if subject %}
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Sujet :</strong> {{ subject }}
                </p>
                {% endif %}
            </td>
        </tr>
    </table>

    <p style="margin:0 0 8px;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:#999999;">
        Message
    </p>
    <div style="background-color:#f8f6f3;padding:20px 24px;border-radius:2px;">
        <p style="margin:0;font-size:14px;color:#333333;line-height:1.7;white-space:pre-wrap;">{{ message }}</p>
    </div>
{% endblock %}
