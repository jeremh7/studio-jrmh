{% extends 'emails/base.html.twig' %}

{% block subject %}[Admin] Compte activé — {{ client.fullName }}{% endblock %}
{% block header_title %}Compte activé{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:20px;font-weight:300;color:#0a0a0a;">
        Un client vient d'activer son espace.
    </h2>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:0 0 24px;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Nom :</strong> {{ client.fullName }}
                </p>
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Email :</strong>
                    <a href="mailto:{{ client.email }}" style="color:#0a0a0a;">{{ client.email }}</a>
                </p>
                {% if client.phone %}
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Téléphone :</strong> {{ client.phone }}
                </p>
                {% endif %}
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Activé le :</strong> {{ "now"|date('d/m/Y à H:i') }}
                </p>
            </td>
        </tr>
    </table>

    <p style="margin:0;font-size:14px;line-height:1.7;color:#777777;">
        Le client peut désormais accéder à ses galeries.
    </p>
{% endblock %}
