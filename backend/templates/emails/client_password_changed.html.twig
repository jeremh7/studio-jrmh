{% extends 'emails/base.html.twig' %}

{% block subject %}Votre mot de passe a été modifié — Studiø JRMH{% endblock %}
{% block header_title %}Sécurité{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonjour {{ client.firstName }}&nbsp;,
    </h2>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#555555;">
        Le mot de passe de votre espace Studiø JRMH a bien été modifié.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#fdf8f0;border-left:3px solid #c8a96e;margin:0 0 28px;">
        <tr>
            <td style="padding:18px 24px;">
                <p style="margin:0 0 6px;font-size:13px;letter-spacing:0.08em;text-transform:uppercase;color:#8a6e3a;font-weight:400;">
                    ⚠ Si vous n'êtes pas à l'origine de cette modification
                </p>
                <p style="margin:0;font-size:14px;line-height:1.6;color:#6b5b3a;">
                    Contactez-nous immédiatement à
                    <a href="mailto:studio.jrmh@gmail.com" style="color:#6b5b3a;font-weight:600;">studio.jrmh@gmail.com</a>
                    — votre compte est peut-être compromis.
                </p>
            </td>
        </tr>
    </table>

    <p style="margin:0;font-size:14px;line-height:1.7;color:#777777;">
        Si c'est bien vous, vous pouvez ignorer cet e-mail. Votre nouveau mot de passe est actif dès maintenant.
    </p>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding:0 40px 36px;text-align:center;">
            <a href="{{ loginUrl }}"
               style="display:inline-block;padding:14px 36px;background-color:#0a0a0a;color:#ffffff;
                      text-decoration:none;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;
                      border-radius:2px;">
                Accéder à mon espace
            </a>
        </td>
    </tr>
{% endblock %}
