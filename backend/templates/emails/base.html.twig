<!DOCTYPE html>
<html lang="fr" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{% block subject %}Studiø JRMH{% endblock %}</title>
    <!--[if mso]>
    <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
    <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f0ede8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0ede8;padding:40px 20px;">
    <tr>
        <td align="center">

            {# Carte principale #}
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
                   style="max-width:600px;width:100%;background-color:#ffffff;border-radius:4px;overflow:hidden;">

                {# ── Header ── #}
                <tr>
                    <td style="background-color:#0a0a0a;padding:36px 40px;text-align:center;">
                        <p style="margin:0;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:#888888;font-weight:400;">
                            Studiø JRMH
                        </p>
                        <p style="margin:8px 0 0;font-size:22px;letter-spacing:0.08em;color:#ffffff;font-weight:300;">
                            {% block header_title %}Photographie{% endblock %}
                        </p>
                    </td>
                </tr>

                {# ── Corps ── #}
                <tr>
                    <td style="padding:44px 40px 36px;">
                        {% block content %}{% endblock %}
                    </td>
                </tr>

                {# ── CTA optionnel ── #}
                {% block cta %}{% endblock %}

                {# ── Séparateur ── #}
                <tr>
                    <td style="padding:0 40px;">
                        <hr style="border:none;border-top:1px solid #e8e4df;margin:0;">
                    </td>
                </tr>

                {# ── Footer ── #}
                <tr>
                    <td style="padding:28px 40px;text-align:center;">
                        {% block footer_extra %}{% endblock %}
                        <p style="margin:0 0 6px;font-size:12px;color:#999999;letter-spacing:0.05em;">
                            Studiø JRMH — Photographie professionnelle
                        </p>
                        <p style="margin:0;font-size:11px;color:#bbbbbb;">
                            Cet e-mail a été généré automatiquement, merci de ne pas y répondre directement.
                        </p>
                    </td>
                </tr>

            </table>

            {# Mention légale sous la carte #}
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
                   style="max-width:600px;width:100%;margin-top:20px;">
                <tr>
                    <td style="text-align:center;padding:0 20px;">
                        <p style="margin:0;font-size:11px;color:#aaaaaa;">
                            © {{ "now"|date("Y") }} Studiø JRMH. Tous droits réservés.
                        </p>
                    </td>
                </tr>
            </table>

        </td>
    </tr>
</table>

</body>
</html>
