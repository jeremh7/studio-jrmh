{% extends 'emails/base.html.twig' %}

{% block subject %}Bienvenue chez Studiø JRMH{% endblock %}
{% block header_title %}Bienvenue{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:24px;font-weight:300;color:#0a0a0a;letter-spacing:0.03em;">
        Bonjour {{ client.firstName }}&nbsp;,
    </h2>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#555555;">
        Votre espace client est maintenant actif sur <strong>Studiø JRMH</strong>.
        Vous pouvez dès maintenant consulter vos galeries photos et télécharger vos fichiers.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:28px 0;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 10px;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:#888888;">
                    Vos informations
                </p>
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Nom :</strong> {{ client.fullName }}
                </p>
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Email :</strong> {{ client.email }}
                </p>
            </td>
        </tr>
    </table>

    <p style="margin:0;font-size:14px;line-height:1.7;color:#777777;">
        N'hésitez pas à me contacter si vous avez la moindre question.
    </p>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding:0 40px 36px;text-align:center;">
            <a href="{{ accessUrl }}"
               style="display:inline-block;padding:14px 36px;background-color:#0a0a0a;color:#ffffff;
                      text-decoration:none;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;
                      border-radius:2px;">
                Accéder à mes galeries
            </a>
        </td>
    </tr>
{% endblock %}
