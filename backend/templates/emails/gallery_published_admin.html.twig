{% extends 'emails/base.html.twig' %}

{% block subject %}[Admin] Galerie publiée — {{ gallery.title }}{% endblock %}
{% block header_title %}Galerie publiée{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:20px;font-weight:300;color:#0a0a0a;">
        Une galerie a été publiée.
    </h2>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:0 0 24px;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Galerie :</strong> {{ gallery.title }}
                </p>
                {% if gallery.description %}
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Description :</strong> {{ gallery.description }}
                </p>
                {% endif %}
                {% if gallery.sessionDate %}
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Date de séance :</strong> {{ gallery.sessionDate|date('d/m/Y') }}
                </p>
                {% endif %}
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Client :</strong> {{ client.fullName }} — {{ client.email }}
                </p>
            </td>
        </tr>
    </table>
{% endblock %}
