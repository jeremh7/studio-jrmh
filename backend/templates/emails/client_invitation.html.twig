{% extends 'emails/base.html.twig' %}

{% block subject %}Votre accès Studiø JRMH — Créez votre mot de passe{% endblock %}
{% block header_title %}Votre accès privé{% endblock %}

{% block content %}
<p style="margin:0 0 20px;font-size:15px;color:#333333;line-height:1.7;">
    Bonjour <strong>{{ client.firstName }}</strong>,
</p>
<p style="margin:0 0 20px;font-size:14px;color:#555555;line-height:1.8;">
    Jérémy Hordé vous a créé un espace client privé sur <strong>Studiø JRMH</strong>.
    Vous y retrouverez vos galeries photos en haute résolution, disponibles au téléchargement.
</p>
<p style="margin:0 0 28px;font-size:14px;color:#555555;line-height:1.8;">
    Pour accéder à votre espace, vous devez d'abord créer votre mot de passe en cliquant sur le bouton ci-dessous.
    Ce lien est valable <strong>72 heures</strong>.
</p>
{% endblock %}

{% block cta %}
<tr>
    <td style="padding:0 40px 40px;text-align:center;">
        <a href="{{ setPasswordUrl }}"
           style="display:inline-block;background-color:#0a0a0a;color:#ffffff;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;padding:16px 36px;border-radius:2px;">
            Créer mon mot de passe →
        </a>
        <p style="margin:20px 0 0;font-size:11px;color:#aaaaaa;">
            Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :<br>
            <span style="color:#777777;word-break:break-all;">{{ setPasswordUrl }}</span>
        </p>
        <p style="margin:16px 0 0;font-size:11px;color:#cccccc;">
            Ce lien expire le {{ expiresAt|date('d/m/Y à H:i') }}.
        </p>
    </td>
</tr>
{% endblock %}

{% block footer_extra %}
<p style="margin:0 0 16px;font-size:12px;color:#aaaaaa;">
    Vous recevez cet email car Jérémy Hordé a créé un compte pour vous.
    Si vous ne souhaitez pas avoir accès à cet espace, ignorez simplement cet email.
</p>
{% endblock %}
