{% extends 'emails/base.html.twig' %}

{% block subject %}Votre espace client a été supprimé — Studiø JRMH{% endblock %}
{% block header_title %}Compte supprimé{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonjour {{ clientName }}&nbsp;,
    </h2>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#555555;">
        Votre espace client associé à l'adresse <strong>{{ clientEmail }}</strong>
        a été supprimé de notre système.
    </p>
    <p style="margin:0 0 24px;font-size:15px;line-height:1.7;color:#555555;">
        Toutes vos données ont été effacées conformément à notre politique de confidentialité.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#fdf8f0;border-left:3px solid #c8a96e;margin:0 0 24px;">
        <tr>
            <td style="padding:18px 24px;">
                <p style="margin:0;font-size:14px;line-height:1.6;color:#6b5b3a;">
                    Si cette suppression n'a pas été demandée par vous ou si vous pensez
                    qu'il s'agit d'une erreur, merci de nous contacter immédiatement.
                </p>
            </td>
        </tr>
    </table>

    <p style="margin:0;font-size:14px;color:#777777;">
        Merci pour votre confiance.
    </p>
{% endblock %}
