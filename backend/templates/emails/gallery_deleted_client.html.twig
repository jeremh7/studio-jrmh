{% extends 'emails/base.html.twig' %}

{% block subject %}Votre galerie "{{ galleryTitle }}" a été supprimée — Studiø JRMH{% endblock %}
{% block header_title %}Galerie supprimée{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonjour {{ client.firstName }}&nbsp;,
    </h2>
    <p style="margin:0 0 24px;font-size:15px;line-height:1.7;color:#555555;">
        Votre galerie <strong>« {{ galleryTitle }} »</strong> a été supprimée.
        Les photos de cette galerie ne sont plus accessibles.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#fdf8f0;border-left:3px solid #c8a96e;margin:0 0 24px;">
        <tr>
            <td style="padding:18px 24px;">
                <p style="margin:0;font-size:14px;line-height:1.6;color:#6b5b3a;">
                    Si vous pensez qu'il s'agit d'une erreur, merci de nous contacter rapidement.
                </p>
            </td>
        </tr>
    </table>
{% endblock %}
