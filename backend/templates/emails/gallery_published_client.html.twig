{% extends 'emails/base.html.twig' %}

{% block subject %}Votre galerie "{{ gallery.title }}" est disponible — Studiø JRMH{% endblock %}
{% block header_title %}Votre galerie{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonne nouvelle, {{ client.firstName }}&nbsp;!
    </h2>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#555555;">
        Votre galerie <strong>« {{ gallery.title }} »</strong> est maintenant disponible.
        Vous pouvez dès maintenant consulter et télécharger vos photos.
    </p>

    {% if gallery.description %}
    <p style="margin:0 0 24px;font-size:15px;line-height:1.7;color:#555555;">
        {{ gallery.description }}
    </p>
    {% endif %}

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:0 0 32px;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Galerie :</strong> {{ gallery.title }}
                </p>
                {% if gallery.sessionDate %}
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Date de la séance :</strong> {{ gallery.sessionDate|date('d/m/Y') }}
                </p>
                {% endif %}
            </td>
        </tr>
    </table>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding:0 40px 36px;text-align:center;">
            <a href="{{ accessUrl }}"
               style="display:inline-block;padding:14px 36px;background-color:#0a0a0a;color:#ffffff;
                      text-decoration:none;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;
                      border-radius:2px;">
                Voir ma galerie
            </a>
        </td>
    </tr>
{% endblock %}
