{% extends 'emails/base.html.twig' %}

{% block subject %}Vos informations ont été mises à jour — Studiø JRMH{% endblock %}
{% block header_title %}Mise à jour{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonjour {{ client.firstName }}&nbsp;,
    </h2>
    <p style="margin:0 0 24px;font-size:15px;line-height:1.7;color:#555555;">
        Vos informations ont été mises à jour avec succès.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color:#f8f6f3;border-left:3px solid #0a0a0a;margin:0 0 24px;">
        <tr>
            <td style="padding:20px 24px;">
                <p style="margin:0 0 6px;font-size:14px;color:#333333;">
                    <strong>Nom :</strong> {{ client.fullName }}
                </p>
                <p style="margin:0;font-size:14px;color:#333333;">
                    <strong>Email :</strong> {{ client.email }}
                </p>
            </td>
        </tr>
    </table>

    <p style="margin:0;font-size:14px;line-height:1.7;color:#777777;">
        Si vous n'êtes pas à l'origine de cette modification, contactez-nous immédiatement.
    </p>
{% endblock %}
