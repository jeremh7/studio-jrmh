{% extends 'emails/base.html.twig' %}

{% block subject %}Réinitialisation de votre mot de passe — Studiø JRMH{% endblock %}
{% block header_title %}Mot de passe{% endblock %}

{% block content %}
    <h2 style="margin:0 0 20px;font-size:22px;font-weight:300;color:#0a0a0a;">
        Bonjour {{ client.firstName }}&nbsp;,
    </h2>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#555555;">
        Vous avez demandé la réinitialisation de votre mot de passe.
        Cliquez sur le bouton ci-dessous pour choisir un nouveau mot de passe.
    </p>
    <p style="margin:0 0 32px;font-size:13px;line-height:1.7;color:#888888;">
        Ce lien est valable <strong>1 heure</strong>. Si vous n'êtes pas à l'origine de cette demande,
        ignorez simplement cet e-mail.
    </p>
{% endblock %}

{% block cta %}
    <tr>
        <td style="padding:0 40px 36px;text-align:center;">
            <a href="{{ resetUrl }}"
               style="display:inline-block;padding:14px 36px;background-color:#0a0a0a;color:#ffffff;
                      text-decoration:none;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;
                      border-radius:2px;">
                Réinitialiser mon mot de passe
            </a>
        </td>
    </tr>
{% endblock %}

{% block footer_extra %}
    <p style="margin:0 0 16px;font-size:12px;color:#aaaaaa;word-break:break-all;">
        Lien alternatif : {{ resetUrl }}
    </p>
{% endblock %}
