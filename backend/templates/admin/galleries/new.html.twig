{% extends 'admin/base.html.twig' %}
{% block title %}Nouvelle galerie{% endblock %}
{% block page_title %}NOUVELLE GALERIE{% endblock %}

{% block content %}
<a href="{{ path('admin_galleries_index') }}" class="back-link">← Galeries</a>

<div style="max-width:660px">
    <div class="page-header">
        <div>
            <div class="page-header-title">NOUVELLE<br>GALERIE</div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Client *</label>
                        <select name="client_id" class="form-control" required>
                            <option value="">— Sélectionner un client —</option>
                            {% for c in clients %}
                            <option value="{{ c.id }}">{{ c.fullName }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Date de session</label>
                        <input type="date" name="session_date" class="form-control">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Titre de la galerie *</label>
                    <input type="text" name="title" class="form-control" required
                           placeholder="Ex: Session sport — Mars 2025">
                </div>

                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control"
                              placeholder="Notes pour le client (optionnel)..."></textarea>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input type="checkbox" name="download_enabled" value="1" checked>
                        Autoriser le téléchargement
                    </label>
                </div>

                <div class="sep"></div>

                <div class="flex-end">
                    <a href="{{ path('admin_galleries_index') }}" class="btn btn-ghost">Annuler</a>
                    <button type="submit" class="btn btn-primary">Créer la galerie →</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
