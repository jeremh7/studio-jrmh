{% extends 'admin/base.html.twig' %}
{% block title %}{{ gallery.title }}{% endblock %}
{% block page_title %}GALERIE{% endblock %}

{% block content %}
<a href="{{ path('admin_galleries_index') }}" class="back-link">← Toutes les galeries</a>

<div class="page-header">
    <div>
        <div class="page-header-title">{{ gallery.title|upper }}</div>
        <div class="page-header-sub" style="margin-top:8px">
            <span class="badge badge-{{ gallery.status }}" style="margin-right:10px">{{ gallery.status }}</span>
            <span style="margin-right:12px">{{ gallery.photoCount }} photo{{ gallery.photoCount > 1 ? 's' : '' }}</span>
            {% if gallery.expiresAt %}
                {% if gallery.isExpired %}
                    <span style="color:var(--danger)">Expiré le {{ gallery.expiresAt|date('d/m/Y') }}</span>
                {% else %}
                    <span>Exp. {{ gallery.expiresAt|date('d/m/Y') }}</span>
                {% endif %}
            {% elseif gallery.status == 'active' %}
                <span style="color:var(--success)">Accès illimité</span>
            {% endif %}
        </div>
    </div>
    <div class="flex-gap">
        <a href="{{ path('admin_galleries_edit', {id: gallery.id}) }}" class="btn btn-ghost">Éditer</a>
        <button onclick="document.getElementById('pub-modal').classList.add('open')" class="btn btn-success">
            {{ gallery.status == 'draft' ? '▶ Publier' : '↺ Republier' }}
        </button>
    </div>
</div>

<div class="grid-2" style="align-items:start">

    <!-- Colonne gauche -->
    <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Infos -->
        <div class="card">
            <div class="card-head">
                <span class="card-head-title">INFORMATIONS</span>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <span class="info-row-label">Client</span>
                    <a href="{{ path('admin_clients_show', {id: gallery.client.id}) }}"
                       class="text-white" style="font-size:15px;font-weight:500">
                        {{ gallery.client.fullName }}
                    </a>
                    <span class="text-muted">{{ gallery.client.email }}</span>
                </div>

                {% if gallery.sessionDate %}
                <div class="info-row">
                    <span class="info-row-label">Session</span>
                    <span class="info-row-value">{{ gallery.sessionDate|date('d F Y') }}</span>
                </div>
                {% endif %}

                {% if gallery.description %}
                <div class="info-row">
                    <span class="info-row-label">Description</span>
                    <span class="info-row-value" style="color:rgba(240,240,240,0.55);font-size:13px">
                        {{ gallery.description }}
                    </span>
                </div>
                {% endif %}

<div class="info-row" style="margin-bottom:0">
                    <span class="info-row-label">Options</span>
                    <div class="flex-gap" style="gap:20px;margin-top:4px">
                        <span style="font-size:12px">
                            DL :
                            <strong class="{{ gallery.downloadEnabled ? 'text-success' : 'text-danger' }}">
                                {{ gallery.downloadEnabled ? 'ON' : 'OFF' }}
                            </strong>
                        </span>
<span style="font-size:12px">
                            Vues : <strong class="text-white mono">{{ gallery.viewCount }}</strong>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Code d'accès -->
        <div class="card">
            <div class="card-head">
                <span class="card-head-title">CODE D'ACCÈS</span>
            </div>
            <div class="card-body" style="text-align:center;padding:32px 24px">
                <div class="access-code-display">{{ gallery.accessCode }}</div>
                <div class="text-muted" style="margin-top:12px;font-size:12px">
                    Code à communiquer au client
                </div>
                <div class="flex-gap" style="justify-content:center;margin-top:20px;gap:8px">
                    <button
                        onclick="navigator.clipboard.writeText('{{ gallery.accessCode }}');this.textContent='✓ Copié';setTimeout(()=>this.textContent='Copier',1500)"
                        class="btn btn-ghost btn-sm">
                        Copier
                    </button>
                    <form method="post" action="{{ path('admin_galleries_regenerate_code', {id: gallery.id}) }}" id="regen-code-form" style="display:inline">
                        <button type="button" class="btn btn-ghost btn-sm"
                                onclick="showDeleteModal('REGÉNÉRER LE CODE', 'L\'ancien code d\'accès ne fonctionnera plus. Le client devra utiliser le nouveau code.', () => document.getElementById('regen-code-form').submit())">
                            Regénérer
                        </button>
                    </form>
                </div>

                {% if gallery.status == 'active' %}
                <div style="margin-top:16px;border-top:0.5px solid var(--border);padding-top:16px;display:flex;flex-direction:column;gap:8px">
                    {# Renvoyer email SANS toucher à expiresAt #}
                    <form method="post" action="{{ path('admin_galleries_resend_notification', {id: gallery.id}) }}">
                        <button class="btn btn-ghost btn-sm" style="width:100%">
                            ✉ Renvoyer l'email client
                        </button>
                    </form>
                    {# Prolonger l'accès SANS republier #}
                    <button onclick="document.getElementById('extend-modal').classList.add('open')" class="btn btn-ghost btn-sm" style="width:100%">
                        ⏱ Prolonger l'accès
                    </button>
                </div>
                {% endif %}
            </div>
        </div>

    </div>

    <!-- Colonne droite — Upload + Photos -->
    <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Upload -->
        <div class="card">
            <div class="card-head">
                <span class="card-head-title">UPLOAD</span>
                <span class="mono text-muted" style="font-size:11px">{{ gallery.photoCount }} photo{{ gallery.photoCount > 1 ? 's' : '' }}</span>
            </div>
            <div class="card-body">
                <div class="upload-zone" id="upload-zone">
                    <input type="file" id="file-input" multiple accept="image/*" style="display:none">
                    <div class="upload-icon">↑</div>
                    <div class="upload-label">Déposer les photos ici</div>
                    <div class="upload-sub">JPG, PNG, WEBP — max 50 MB par fichier</div>
                </div>
                <div id="upload-progress" style="display:none;margin-top:14px">
                    <div id="upload-bar" style="height:2px;background:var(--border);margin-bottom:8px;overflow:hidden">
                        <div id="upload-bar-fill" style="height:100%;width:0%;background:var(--gold);transition:width 0.3s"></div>
                    </div>
                    <div id="upload-status" class="mono text-success" style="font-size:10px;letter-spacing:.1em"></div>
                </div>
            </div>
        </div>

        <!-- Grille photos -->
        <div class="card">
            <div class="card-head">
                <span class="card-head-title">PHOTOS</span>
                <button id="reorder-hint" class="btn btn-ghost btn-sm" style="display:none" onclick="saveOrder()">
                    ↕ Sauvegarder l'ordre
                </button>
            </div>
            <div class="card-body">
                <div class="photo-grid" id="photo-grid">
                    {% for photo in gallery.photos %}
                    <div class="photo-item" data-id="{{ photo.id }}">
                        <img src="{{ photo.publicUrl }}"
                             alt="{{ photo.originalFilename }}"
                             loading="lazy"
                             style="width:100%;height:100%;object-fit:cover;display:block">
                        <div class="photo-overlay">
                            <div style="font-size:9px;color:rgba(255,255,255,0.5);margin-bottom:6px;text-align:center">
                                {{ photo.fileSizeFormatted }}
                            </div>
                            <button class="btn btn-danger btn-sm" style="width:100%"
                                    onclick="deletePhoto({{ photo.id }}, this)">
                                ✕ Suppr.
                            </button>
                        </div>
                        <div class="photo-drag-handle" title="Glisser pour réordonner">⠿</div>
                    </div>
                    {% else %}
                    <div id="empty-grid" style="grid-column:span 3;text-align:center;padding:40px;color:var(--muted);font-size:12px">
                        Aucune photo. Uploadez des images ci-dessus.
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Modal publication -->
<div id="pub-modal" class="modal-overlay">
    <div class="modal">
        <div class="modal-head">
            <span class="modal-head-title">{{ gallery.status == 'draft' ? 'PUBLIER' : 'REPUBLIER' }}</span>
            <button class="modal-close" onclick="document.getElementById('pub-modal').classList.remove('open')">✕</button>
        </div>
        <div class="modal-body">
            <form method="post" action="{{ path('admin_galleries_publish', {id: gallery.id}) }}">
                <div class="form-group">
                    <label class="form-label">Durée d'accès</label>
                    <select name="days_valid" class="form-control">
                        <option value="30" selected>30 jours</option>
                        <option value="60">60 jours</option>
                        <option value="90">90 jours</option>
                        <option value="unlimited">Accès illimité ∞</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input type="checkbox" name="send_email" value="1" checked>
                        Envoyer l'email à {{ gallery.client.email }}
                    </label>
                </div>

                <div style="background:var(--bg3);border:0.5px solid var(--border2);padding:14px;margin-bottom:20px">
                    <div class="mono text-muted" style="font-size:9px;letter-spacing:.12em;margin-bottom:6px">Code d'accès</div>
                    <div class="mono text-white" style="font-size:20px;letter-spacing:.35em">{{ gallery.accessCode }}</div>
                </div>

                <div class="flex-end">
                    <button type="button" class="btn btn-ghost"
                            onclick="document.getElementById('pub-modal').classList.remove('open')">
                        Annuler
                    </button>
                    <button type="submit" class="btn btn-success">▶ Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal prolongation -->
<div id="extend-modal" class="modal-overlay">
    <div class="modal">
        <div class="modal-head">
            <span class="modal-head-title">PROLONGER L'ACCÈS</span>
            <button class="modal-close" onclick="document.getElementById('extend-modal').classList.remove('open')">✕</button>
        </div>
        <div class="modal-body">
            <form method="post" action="{{ path('admin_galleries_extend', {id: gallery.id}) }}">
                {% if gallery.expiresAt %}
                <p class="text-muted" style="font-size:12px;margin-bottom:16px">
                    Expiration actuelle : <strong class="text-white">{{ gallery.expiresAt|date('d/m/Y') }}</strong><br>
                    La durée s'ajoute à partir de la date actuelle d'expiration.
                </p>
                {% else %}
                <p class="text-muted" style="font-size:12px;margin-bottom:16px">
                    Accès actuellement <strong class="text-success">illimité</strong>.
                </p>
                {% endif %}
                <div class="form-group">
                    <label class="form-label">Prolonger de</label>
                    <select name="days_valid" class="form-control">
                        <option value="30">+ 30 jours</option>
                        <option value="60">+ 60 jours</option>
                        <option value="90">+ 90 jours</option>
                        <option value="unlimited">Rendre illimité ∞</option>
                    </select>
                </div>
                <div class="flex-end">
                    <button type="button" class="btn btn-ghost"
                            onclick="document.getElementById('extend-modal').classList.remove('open')">
                        Annuler
                    </button>
                    <button type="submit" class="btn btn-primary">Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<style>
.photo-drag-handle {
    position:absolute;top:4px;left:4px;
    color:rgba(255,255,255,0.4);font-size:14px;
    cursor:grab;line-height:1;padding:2px;
    text-shadow:0 1px 2px rgba(0,0,0,0.8);
}
.photo-item { position:relative; }
.sortable-ghost { opacity:0.3; }
</style>
<script>
async function deletePhoto(photoId, btn) {
    showDeleteModal('SUPPRIMER LA PHOTO', 'Cette photo sera définitivement supprimée de la galerie.', async () => {

    const item = btn.closest('.photo-item');
    btn.disabled = true;
    btn.textContent = '…';

    try {
        const res = await fetch(`/admin/galleries/photos/${photoId}/delete`, { method: 'POST' });
        if (!res.ok) throw new Error();

        // Fondu puis suppression du DOM
        item.style.transition = 'opacity 0.25s, transform 0.25s';
        item.style.opacity = '0';
        item.style.transform = 'scale(0.9)';
        setTimeout(() => {
            item.remove();
            // Affiche le placeholder si la grille est vide
            if (!document.querySelector('.photo-item')) {
                const empty = document.getElementById('empty-grid');
                if (empty) empty.style.display = '';
            }
        }, 260);
    } catch {
        btn.disabled = false;
        btn.textContent = '✕ Suppr.';
        alert('Erreur lors de la suppression.');
    }
    }); // fin showDeleteModal
}

const zone       = document.getElementById('upload-zone');
const input      = document.getElementById('file-input');
const progress   = document.getElementById('upload-progress');
const barFill    = document.getElementById('upload-bar-fill');
const statusEl   = document.getElementById('upload-status');
const grid       = document.getElementById('photo-grid');
const emptyGrid  = document.getElementById('empty-grid');
const reorderBtn = document.getElementById('reorder-hint');

zone.addEventListener('click', () => input.click());
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
zone.addEventListener('drop', e => { e.preventDefault(); zone.classList.remove('drag-over'); upload(e.dataTransfer.files); });
input.addEventListener('change', () => upload(input.files));

async function upload(files) {
    if (!files.length) return;
    progress.style.display = 'block';
    barFill.style.width = '0%';
    statusEl.style.color = 'var(--muted)';
    statusEl.textContent = `Traitement de ${files.length} fichier(s)…`;

    const fd = new FormData();
    for (const f of files) fd.append('photos[]', f);

    // Simule la progression (l'upload est synchrone côté serveur)
    let pct = 0;
    const ticker = setInterval(() => { pct = Math.min(pct + 8, 90); barFill.style.width = pct + '%'; }, 200);

    try {
        const r = await fetch('{{ path('admin_galleries_upload', {id: gallery.id}) }}', { method: 'POST', body: fd });

        if (r.status === 302 || r.redirected) {
            clearInterval(ticker);
            statusEl.style.color = 'var(--danger)';
            statusEl.textContent = '✕ Session expirée — rechargez la page et reconnectez-vous.';
            return;
        }
        if (!r.headers.get('content-type')?.includes('application/json')) {
            clearInterval(ticker);
            statusEl.style.color = 'var(--danger)';
            statusEl.textContent = `✕ Erreur serveur (${r.status}) — vérifiez les logs Railway.`;
            return;
        }

        const d = await r.json();

        clearInterval(ticker);
        barFill.style.width = '100%';

        if (d.errors.length && !d.uploaded.length) {
            statusEl.style.color = 'var(--danger)';
            statusEl.textContent = `✕ ${d.errors.join(' | ')}`;
        } else {
            statusEl.style.color = 'var(--success)';
            statusEl.textContent = `✓ ${d.uploaded.length} photo(s) ajoutée(s)` + (d.errors.length ? ` — ${d.errors.length} erreur(s)` : '');
        }

        if (emptyGrid) emptyGrid.remove();

        d.uploaded.forEach(p => {
            const div = document.createElement('div');
            div.className = 'photo-item';
            div.dataset.id = p.id;
            div.innerHTML = `
                <img src="${p.url}" alt="${p.name}" loading="lazy"
                     style="width:100%;height:100%;object-fit:cover;display:block">
                <div class="photo-overlay">
                    <div style="font-size:9px;color:rgba(255,255,255,0.5);margin-bottom:6px;text-align:center">${p.size}</div>
                    <button class="btn btn-danger btn-sm" style="width:100%" onclick="deletePhoto(${p.id}, this)">✕ Suppr.</button>
                </div>
                <div class="photo-drag-handle" title="Glisser pour réordonner">⠿</div>`;
            grid.appendChild(div);
        });

        if (d.errors.length) console.warn('Erreurs upload :', d.errors);

        // Actualise le compteur dans le header
        const countEl = document.querySelector('.card-head .mono.text-muted');
        if (countEl) countEl.textContent = d.total + ' photo' + (d.total > 1 ? 's' : '');

    } catch (err) {
        clearInterval(ticker);
        statusEl.style.color = 'var(--danger)';
        statusEl.textContent = '✕ Erreur réseau : ' + err.message;
    }
}

// Réordonnancement drag-and-drop
function saveOrder() {
    const ids = [...grid.querySelectorAll('.photo-item')].map(el => el.dataset.id);
    fetch('{{ path('admin_galleries_reorder', {id: gallery.id}) }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
    }).then(() => {
        reorderBtn.textContent = '✓ Ordre sauvegardé';
        setTimeout(() => { reorderBtn.textContent = '↕ Sauvegarder l\'ordre'; reorderBtn.style.display = 'none'; }, 2000);
    });
}

// Drag-and-drop natif sur la grille
let dragSrc = null;
grid.addEventListener('dragstart', e => {
    dragSrc = e.target.closest('.photo-item');
    if (!dragSrc) return;
    dragSrc.style.opacity = '0.4';
    e.dataTransfer.effectAllowed = 'move';
});
grid.addEventListener('dragend', e => {
    const item = e.target.closest('.photo-item');
    if (item) item.style.opacity = '';
});
grid.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.photo-item');
    if (target && target !== dragSrc) {
        const rect = target.getBoundingClientRect();
        const after = e.clientX > rect.left + rect.width / 2;
        grid.insertBefore(dragSrc, after ? target.nextSibling : target);
        reorderBtn.style.display = '';
    }
});

// Activer le draggable sur les items existants
document.querySelectorAll('.photo-item').forEach(el => el.setAttribute('draggable', 'true'));
</script>
{% endblock %}
