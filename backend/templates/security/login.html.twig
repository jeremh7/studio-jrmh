<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion — JRMH</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #080808;
            color: #F0F0F0;
            font-family: 'Space Mono', monospace;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
        }

        .wrap {
            width: 100%;
            max-width: 380px;
            padding: 0 24px;
        }

        .logo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 56px;
            letter-spacing: .12em;
            color: #fff;
            line-height: 1;
            margin-bottom: 4px;
        }

        .sub {
            font-size: 8px;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: rgba(240,240,240,0.25);
            margin-bottom: 56px;
        }

        .error {
            background: rgba(255,69,69,0.06);
            border-left: 2px solid #FF4545;
            color: #FF4545;
            padding: 10px 14px;
            font-size: 11px;
            letter-spacing: .05em;
            margin-bottom: 28px;
        }

        .label {
            display: block;
            font-size: 8px;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: rgba(240,240,240,0.35);
            margin-bottom: 8px;
        }

        .input {
            width: 100%;
            background: #0f0f0f;
            border: 0.5px solid rgba(240,240,240,0.15);
            color: #F0F0F0;
            padding: 13px 14px;
            font-family: 'Space Mono', monospace;
            font-size: 13px;
            outline: none;
            margin-bottom: 20px;
            transition: border-color .12s;
            border-radius: 0;
        }

        .input:focus { border-color: rgba(240,240,240,0.5); }
        .input::placeholder { color: rgba(240,240,240,0.12); }

        .check {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 11px;
            color: rgba(240,240,240,0.3);
            margin-bottom: 28px;
            cursor: pointer;
        }

        .check input { accent-color: #fff; width: 13px; height: 13px; }

        .btn {
            width: 100%;
            background: #fff;
            color: #080808;
            border: none;
            padding: 14px;
            font-family: 'Space Mono', monospace;
            font-size: 9px;
            letter-spacing: .25em;
            text-transform: uppercase;
            font-weight: 700;
            cursor: pointer;
            transition: background .12s;
        }

        .btn:hover { background: #e0e0e0; }

        .footer-line {
            margin-top: 40px;
            font-size: 8px;
            letter-spacing: .12em;
            color: rgba(240,240,240,0.12);
        }
    </style>
</head>
<body>
<div class="wrap">
    <div class="logo">JRMH</div>
    <div class="sub">Studio — Administration</div>

    {% if error %}
        <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post">
        <label class="label" for="username">Email</label>
        <input id="username" class="input" type="email" name="_username"
               value="{{ last_username }}" autocomplete="email" autofocus>

        <label class="label" for="password">Mot de passe</label>
        <input id="password" class="input" type="password"
               name="_password" autocomplete="current-password">

        <label class="check">
            <input type="checkbox" name="_remember_me">
            Rester connecté
        </label>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button class="btn">Connexion →</button>
    </form>

    <div class="footer-line">© {{ "now"|date("Y") }} Studiø JRMH</div>
</div>
</body>
</html>
